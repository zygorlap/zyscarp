# Zygor Scarper Environment Configuration
# Copy this to .env and configure as needed

# Target Configuration
ZYGOR_TARGET=https://example.com
ZYGOR_MODE=fast
ZYGOR_PRESET=gentle
ZYGOR_MAX_PAGES=500
ZYGOR_CONCURRENT=16

# Output & Logging
ZYGOR_OUTPUT=./output
ZYGOR_LOG_LEVEL=info
ZYGOR_LOG_FILE=./logs/zygor.log
ZYGOR_LOG_FORMAT=json

# Timing & Performance
ZYGOR_TIMEOUT=20000
ZYGOR_DELAY=200
ZYGOR_RATE_LIMIT=1000

# Features
ZYGOR_DOWNLOAD=true
ZYGOR_CRAWL=true
ZYGOR_API_SCRAPING=true
ZYGOR_SECRET_EXTRACTION=false
ZYGOR_ERROR_BYPASS=true
ZYGOR_SCREENSHOTS=true
ZYGOR_ZIP=true
ZYGOR_INTEL=true
ZYGOR_METRICS=true

# Advanced Options
ZYGOR_RESPECT_ROBOTS_TXT=true
ZYGOR_USER_AGENT_ROTATION=true
ZYGOR_RETRIES=5
ZYGOR_PROXY=

# Caching & Performance
ZYGOR_CACHING=false
ZYGOR_DELTA_SYNC=false
ZYGOR_COMPRESSION=false

# Webhooks & Notifications
ZYGOR_WEBHOOK_URL=
ZYGOR_WEBHOOK_EVENTS=complete,error

# Database (Optional)
ZYGOR_DATABASE_URL=

# Export Configuration
ZYGOR_EXPORT_FORMATS=json
ZYGOR_INCLUDE_METRICS=true
ZYGOR_INCLUDE_REPORT=true

# Dashboard
ZYGOR_DASHBOARD_PORT=3000
ZYGOR_DASHBOARD_ENABLED=true

# Development
DEBUG=false
NODE_ENV=production
